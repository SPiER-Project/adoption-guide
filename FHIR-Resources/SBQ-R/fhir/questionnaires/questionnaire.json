{
  "resourceType": "Questionnaire",
  "id": "SBQ-R",
  "url": "http://spier.org/Questionnaire/SBQ-R",
  "version": "1.0.0",
  "name": "SBQR",
  "title": "Suicide Behaviors Questionnaire-Revised (SBQ-R)",
  "status": "draft",
  "experimental": true,
  "subjectType": ["Patient"],
  "date": "2026-03-19",
  "publisher": "SPiER Project (FHIR translation)",
  "description": "FHIR Questionnaire representation of the Suicide Behaviors Questionnaire-Revised (SBQ-R). A 4-item self-report measure where each item taps a different dimension of suicidality: lifetime ideation/attempt, past-year frequency, threat of attempt, and future likelihood. Total score range: 3-18. Cutoff scores: ≥7 for general population (93% sensitivity, 95% specificity), ≥8 for psychiatric inpatients (80% sensitivity, 91% specificity).",
  "purpose": "Suicide risk screening. Scoring: Item 1 (1-4 pts), Item 2 (1-5 pts), Item 3 (1-3 pts), Item 4 (0-6 pts). Total 3-18. General population cutoff ≥7, psychiatric inpatient cutoff ≥8.",
  "copyright": "© Osman et al (1999) Revised. Permission for use granted by A. Osman, MD. Reference: Osman A, Bagge CL, Guitierrez PM, Konick LC, Kooper BA, Barrios FX. The Suicidal Behaviors Questionnaire-Revised (SBQ-R): Validation with clinical and nonclinical samples. Assessment, 2001, (5), 443-454.",
  "item": [
    {
      "linkId": "q1",
      "text": "Have you ever thought about or attempted to kill yourself?",
      "type": "choice",
      "required": true,
      "answerOption": [
        {
          "valueCoding": {
            "system": "http://spier.org/CodeSystem/sbqr-q1",
            "code": "1",
            "display": "Never"
          },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 1 }]
        },
        {
          "valueCoding": {
            "system": "http://spier.org/CodeSystem/sbqr-q1",
            "code": "2",
            "display": "It was just a brief passing thought"
          },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 2 }]
        },
        {
          "valueCoding": {
            "system": "http://spier.org/CodeSystem/sbqr-q1",
            "code": "3a",
            "display": "I have had a plan at least once to kill myself but did not try to do it"
          },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 3 }]
        },
        {
          "valueCoding": {
            "system": "http://spier.org/CodeSystem/sbqr-q1",
            "code": "3b",
            "display": "I have had a plan at least once to kill myself and really wanted to die"
          },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 3 }]
        },
        {
          "valueCoding": {
            "system": "http://spier.org/CodeSystem/sbqr-q1",
            "code": "4a",
            "display": "I have attempted to kill myself, but did not want to die"
          },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 4 }]
        },
        {
          "valueCoding": {
            "system": "http://spier.org/CodeSystem/sbqr-q1",
            "code": "4b",
            "display": "I have attempted to kill myself, and really hoped to die"
          },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 4 }]
        }
      ]
    },
    {
      "linkId": "q2",
      "text": "How often have you thought about killing yourself in the past year?",
      "type": "choice",
      "required": true,
      "answerOption": [
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q2", "code": "1", "display": "Never" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 1 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q2", "code": "2", "display": "Rarely (1 time)" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 2 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q2", "code": "3", "display": "Sometimes (2 times)" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 3 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q2", "code": "4", "display": "Often (3-4 times)" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 4 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q2", "code": "5", "display": "Very Often (5 or more times)" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 5 }]
        }
      ]
    },
    {
      "linkId": "q3",
      "text": "Have you ever told someone that you were going to commit suicide, or that you might do it?",
      "type": "choice",
      "required": true,
      "answerOption": [
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q3", "code": "1", "display": "No" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 1 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q3", "code": "2a", "display": "Yes, at one time, but did not really want to die" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 2 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q3", "code": "2b", "display": "Yes, at one time, and really wanted to die" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 2 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q3", "code": "3a", "display": "Yes, more than once, but did not want to do it" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 3 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q3", "code": "3b", "display": "Yes, more than once, and really wanted to do it" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 3 }]
        }
      ]
    },
    {
      "linkId": "q4",
      "text": "How likely is it that you will attempt suicide someday?",
      "type": "choice",
      "required": true,
      "answerOption": [
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q4", "code": "0", "display": "Never" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 0 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q4", "code": "1", "display": "No chance at all" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 1 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q4", "code": "2", "display": "Rather unlikely" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 2 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q4", "code": "3", "display": "Unlikely" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 3 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q4", "code": "4", "display": "Likely" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 4 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q4", "code": "5", "display": "Rather likely" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 5 }]
        },
        {
          "valueCoding": { "system": "http://spier.org/CodeSystem/sbqr-q4", "code": "6", "display": "Very likely" },
          "extension": [{ "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue", "valueDecimal": 6 }]
        }
      ]
    },
    {
      "linkId": "total-score",
      "text": "SBQ-R Total Score (range 3-18)",
      "type": "integer",
      "readOnly": true,
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
            "description": "Sum of the ordinal weights of all 4 item answers (SDC weight() resolves each answer's ordinalValue from the Questionnaire answerOption). Range 3-18. Cutoff ≥7 general population, ≥8 psychiatric inpatients.",
            "language": "text/fhirpath",
            "expression": "%resource.item.where(linkId.startsWith('q')).answer.weight().sum()"
          }
        }
      ]
    }
  ]
}
