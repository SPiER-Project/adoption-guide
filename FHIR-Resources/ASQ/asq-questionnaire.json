      "text": "Ask the patient:",
      "type": "group",
      "item": [
        {
          "linkId": "q1",
          "text": "In the past few weeks, have you wished you were dead?",
          "type": "choice",
          "required": true,
          "answerOption": [
            {
              "valueCoding": {
                "system": "http://snomed.info/sct",
                "code": "373066001",
                "display": "Yes"
              }
            },
            {
              "valueCoding": {
                "system": "http://snomed.info/sct",
                "code": "373067005",
                "display": "No"
              }
            }
          ],
          "code": [
            {
              "system": "http://spier.org/CodeSystem/asq-item",
              "code": "wished-dead",
              "display": "Wished you were dead",
              "extension": [
                {
                  "url": "http://spier.org/StructureDefinition/coding-verification-status",
                  "valueCode": "no-standard-binding"
                }
              ]
            }
          ],
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract",
              "valueBoolean": true
            }
          ]
        },
        {
