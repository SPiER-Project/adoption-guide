  "item": [
    {
      "linkId": "opening-script",
      "text": "Opening script: “Now I’m going to ask you some questions that we ask everyone treated here, no matter what problem they are here for. It is part of the hospital’s policy and it helps us to make sure we are not missing anything important.” (Ages 12+. Ask the three questions exactly as worded; if Question 3 is Yes, ask 3a.)",
      "type": "display"
    },
    {
      "linkId": "q1-depression",
      "text": "In the past two weeks, have you felt down, depressed, or hopeless?",
      "type": "choice",
      "required": true,
      "code": [
        {
          "system": "http://spier.org/CodeSystem/pss3-item",
          "code": "depression-2wk",
          "display": "Depression in the past two weeks",
          "extension": [
            { "url": "http://spier.org/StructureDefinition/coding-verification-status", "valueCode": "no-standard-binding" }
          ]
        }
      ],
      "answerOption": [
        { "valueCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } },
        { "valueCoding": { "system": "http://snomed.info/sct", "code": "373067005", "display": "No" } },
        { "valueCoding": { "system": "http://spier.org/CodeSystem/pss3-answer", "code": "unable-to-complete", "display": "Patient unable to complete" } },
        { "valueCoding": { "system": "http://spier.org/CodeSystem/pss3-answer", "code": "patient-refused", "display": "Patient refused" } }
      ],
      "extension": [
        { "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract", "valueBoolean": true }
      ]
    },
    {
      "linkId": "q2-ideation",
