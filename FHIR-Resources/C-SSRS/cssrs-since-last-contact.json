{
  "resourceType": "Questionnaire",
  "id": "C-SSRS-Since-Last-Contact",
  "url": "http://spier.org/Questionnaire/C-SSRS-Since-Last-Contact",
  "version": "1.0.0",
  "name": "CSSRS_Since_Last_Contact",
  "title": "Columbia-Suicide Severity Rating Scale — Since Last Visit / Since Last Contact",
  "status": "draft",
  "experimental": true,
  "subjectType": [
    "Patient"
  ],
  "date": "2026-07-15",
  "publisher": "SPiER Project (FHIR translation)",
  "description": "FHIR Questionnaire representation of the C-SSRS Since Last Visit / Since Last Contact version — a repeat suicide-risk assessment that covers only the interval since the patient's prior contact rather than lifetime/recent. Item set, LOINC coding, conditional logic, and three-tier risk stratification are identical to the C-SSRS Screener (Recent); the difference is the administration reference period, which is expressed in the instructions. Used to reassess risk over the interval and update the current risk workflow.",
  "purpose": "Interval suicide-risk reassessment. Questions 1-2 are always asked; Questions 3-5 are conditional on Q2=Yes; Question 6 (suicidal behavior) is always asked — all framed to the period since the patient's last visit/contact. Risk tiers: Q1-Q2 positive = Low, Q3-Q4 positive = Moderate, Q5 or Q6 positive = High. Belongs to the Clarify Risk stage as a repeat assessment.",
  "copyright": "© 2008 The Research Foundation for Mental Hygiene, Inc. Developed by Posner, K.; Brent, D.; Lucas, C.; Gould, M.; Stanley, B.; Brown, G.; Fisher, P.; Zelazny, J.; Burke, A.; Oquendo, M.; Mann, J. Used with registration; training required for administration. For inquiries and training: posnerk@nyspi.columbia.edu",
  "code": [
    {
      "system": "http://loinc.org",
      "code": "93373-9",
      "display": "Columbia-suicide severity rating scale screener - recent"
    }
  ],
  "item": [
    {
      "linkId": "since-last-visit-instruction",
      "text": "Since Last Visit / Since Last Contact — ask each question about the period since the patient's last visit or contact (not lifetime).",
      "type": "display"
    },
    {
      "linkId": "ideation-section",
      "text": "Suicide Ideation (since last visit/contact)",
      "type": "group",
      "item": [
        {
          "linkId": "q1",
          "text": "Have you wished you were dead or wished you could go to sleep and not wake up?",
          "type": "choice",
          "required": true,
          "code": [
            { "system": "http://loinc.org", "code": "93246-7", "display": "Wish to be dead" }
          ],
          "extension": [
            { "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract", "valueBoolean": true }
          ],
          "answerOption": [
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } },
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373067005", "display": "No" } }
          ]
        },
        {
          "linkId": "q2",
          "text": "Have you actually had any thoughts of killing yourself?",
          "type": "choice",
          "required": true,
          "code": [
            { "system": "http://loinc.org", "code": "93247-5", "display": "Non-specific active suicidal thoughts" }
          ],
          "extension": [
            { "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract", "valueBoolean": true }
          ],
          "answerOption": [
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } },
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373067005", "display": "No" } }
          ]
        },
        {
          "linkId": "q3",
          "text": "Have you been thinking about how you might do this?",
          "type": "choice",
          "required": true,
          "enableWhen": [
            { "question": "q2", "operator": "=", "answerCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } }
          ],
          "code": [
            { "system": "http://loinc.org", "code": "93248-3", "display": "Active suicidal ideation with any methods (not plan) without intent to act" }
          ],
          "extension": [
            { "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract", "valueBoolean": true }
          ],
          "answerOption": [
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } },
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373067005", "display": "No" } }
          ]
        },
        {
          "linkId": "q4",
          "text": "Have you had these thoughts and had some intention of acting on them?",
          "type": "choice",
          "required": true,
          "enableWhen": [
            { "question": "q2", "operator": "=", "answerCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } }
          ],
          "code": [
            { "system": "http://loinc.org", "code": "93249-1", "display": "Active suicidal ideation with some intent to act without specific plan" }
          ],
          "extension": [
            { "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract", "valueBoolean": true }
          ],
          "answerOption": [
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } },
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373067005", "display": "No" } }
          ]
        },
        {
          "linkId": "q5",
          "text": "Have you started to work out or worked out the details of how to kill yourself? Do you intend to carry out this plan?",
          "type": "choice",
          "required": true,
          "enableWhen": [
            { "question": "q2", "operator": "=", "answerCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } }
          ],
          "code": [
            { "system": "http://loinc.org", "code": "93250-9", "display": "Active suicidal ideation with specific plan and intent" }
          ],
          "extension": [
            { "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract", "valueBoolean": true }
          ],
          "answerOption": [
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } },
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373067005", "display": "No" } }
          ]
        }
      ]
    },
    {
      "linkId": "behavior-section",
      "text": "Suicidal Behavior (since last visit/contact)",
      "type": "group",
      "item": [
        {
          "linkId": "q6",
          "text": "Have you done anything, started to do anything, or prepared to do anything to end your life?",
          "type": "choice",
          "required": true,
          "code": [
            { "system": "http://loinc.org", "code": "93267-3", "display": "Have you ever done anything, started to do anything, or prepared to do anything to end your life" }
          ],
          "extension": [
            { "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract", "valueBoolean": true }
          ],
          "answerOption": [
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373066001", "display": "Yes" } },
            { "valueCoding": { "system": "http://snomed.info/sct", "code": "373067005", "display": "No" } }
          ]
        }
      ]
    },
    {
      "linkId": "risk-level",
      "text": "Suicide Risk Level",
      "type": "choice",
      "required": true,
      "code": [
        { "system": "http://loinc.org", "code": "93374-7", "display": "Suicide risk level" }
      ],
      "answerOption": [
        { "valueCoding": { "system": "http://spier.org/CodeSystem/cssrs-risk-level", "code": "low", "display": "Low Risk" } },
        { "valueCoding": { "system": "http://spier.org/CodeSystem/cssrs-risk-level", "code": "moderate", "display": "Moderate Risk" } },
        { "valueCoding": { "system": "http://spier.org/CodeSystem/cssrs-risk-level", "code": "high", "display": "High Risk" } }
      ],
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
          "valueCodeableConcept": {
            "coding": [{ "system": "http://hl7.org/fhir/questionnaire-item-control", "code": "radio-button", "display": "Radio Button" }]
          }
        }
      ]
    }
  ]
}
