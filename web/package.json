{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "copy-fhir": "node scripts/copy-fhir.mjs",
    "fetch-roadmap": "node scripts/fetch-roadmap.mjs",
    "predev": "npm run copy-fhir",
    "dev": "vite",
    "prebuild": "npm run copy-fhir -- --force",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "check:extract": "node scripts/check-observation-extract.mjs",
    "check:crosswalk": "node scripts/check-concept-crosswalk.mjs",
    "check:catalog": "node scripts/check-catalog-integrity.mjs",
    "check:stages": "node scripts/check-stage-ids.mjs",
    "check:fallback": "node scripts/check-fallback-signatures.mjs",
    "test": "vitest run",
    "verify": "npm run copy-fhir -- --force && tsc -b && npm run lint && npm run lint:css && npm run check:crosswalk && npm run check:extract && npm run check:catalog && npm run check:stages && npm run check:fallback && npm test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@formbox/hs-theme": "^0.2.1",
    "@formbox/renderer": "^0.2.1",
    "fhirclient": "^2.6.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fsh-sushi": "^3.19.0",
    "globals": "^16.5.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  }
}
