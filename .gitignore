# OS metadata
.DS_Store
Thumbs.db

# Editor scratch / swap files
*.swp
*.swo
*~
.idea/
.vscode/

# Firebase / deploy debug
firebase-debug.log
firebase-debug.*.log
.firebase/

# Node / build artifacts that shouldn't be in source control
node_modules/

# FHIR resources copied from ig/fsh-generated/ at build time
# (source of truth is ig/input/fsh/; regenerated by web/scripts/copy-fhir.mjs)
web/src/data/fhir/

# TS modules generated alongside copy-fhir (e.g. care-plan-profiles.generated.ts)
web/src/data/catalog/*.generated.ts

# Local environment secrets
.env
.env.local
.env.*.local
